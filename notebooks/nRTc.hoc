    forsec axon_group {
        insert naf2__a0__b0__c0__d0__fastNa_shift0
        gmax_naf2__a0__b0__c0__d0__fastNa_shift0 = 0.39999998  // units: S cm-2
        ena = 50.0  // units: mV
    }
    forsec axon_group {
        insert pas_nml2
        gmax_pas_nml2 = 9.999999E-4  // units: S cm-2
        e_pas_nml2 = -75.0  // units: mV
    }
    forsec soma_group {
        insert pas_nml2
        gmax_pas_nml2 = 5.0E-5  // units: S cm-2
        e_pas_nml2 = -75.0  // units: mV
    }
    forsec dendrite_group {
        insert pas_nml2
        gmax_pas_nml2 = 5.0E-5  // units: S cm-2
        e_pas_nml2 = -75.0  // units: mV
    }
    forsec axon_group {
        insert pas_nml2
        gmax_pas_nml2 = 5.0E-5  // units: S cm-2
        e_pas_nml2 = -75.0  // units: mV
    }

    // Concentration models for species

}

func H() { // Heaviside function
    if ($1>=0) return 1
    if ($1==0) return 0.5
    return 0
}

