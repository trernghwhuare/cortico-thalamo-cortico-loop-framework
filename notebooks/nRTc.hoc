proc biophys() {

    // Specific capacitance
    forsec all cm = 1.3000001  // units: uF/cm2

    // Specific axial resistance/resistivity
    forsec all Ra = 150.0  // units: ohm cm

    // Channel densities
    forsec soma_group {
        insert ar__m00
        gmax_ar__m00 = 2.5E-5  // units: S cm-2
        ear = -40.0  // units: mV
    }
    forsec dendrite_group {
        insert ar__m00
        gmax_ar__m00 = 2.5E-5  // units: S cm-2
        ear = -40.0  // units: mV
    }
    forsec soma_group {
        insert cal
        gmax_cal = 4.9999997E-4  // units: S cm-2
        eca = 125.0  // units: mV
    }
    forsec dendrite_group {
        insert cal
        gmax_cal = 4.9999997E-4  // units: S cm-2
        eca = 125.0  // units: mV
    }
    forsec soma_group {
        insert cat_a
        gmax_cat_a = 1.0E-4  // units: S cm-2
        eca = 125.0  // units: mV
